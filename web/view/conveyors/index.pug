extend ../layout/default.pug

block main 
    .page 
        .dashboard_header
            .dashboard_heading
                h1.dashboard_title Quản lý băng tải
                p.dashboard_subtitle Tạo, cập nhật, xóa băng tải trong hệ thống

            .dashboard-actions
                a.btn.btn-primary(href="/conveyors/create") Thêm băng tải mới

    if error
      .alert.alert--error
        | #{error}

    .card.history-filter-card
        form.history-filters(method="GET" action="/conveyors")
            .field
                label.field__label(for="keyword") Tìm kiếm băng tải
                input#keyword.field__control(
                    type="text"
                    name="keyword"
                    value=filters.keyword
                    placeholder="Nhập mã hoặc tên băng tải... "
                )
            .field
                label.field__label(for="status") Trạng thái băng tải
                select#status.field__control(name="status")
                    option(value="" selected=!filters.status) Tất cả
                    option(value="READY" selected=filters.status === "READY") Sẵn sàng
                    option(value="OFFLINE" selected=filters.status === "OFFLINE") Offline
                    option(value="ERROR" selected=filters.status === "ERROR") Lỗi
                    option(value="RUNNING" selected=filters.status === "RUNNING") Đang hoạt động
                    option(value="STOP" selected=filters.status === "STOP") Stop
            .history-filters__actions
                button.btn.btn--primary(type="submit") Lọc
                a.btn.btn-secondary(href="/conveyors") Xóa
            
    .card
        .table-wrap 
            table.table
                thead
                    tr 
                        th Mã băng tải
                        th Tên băng tải
                        //th Dây chuyền
                        th Người vận hành
                        th Trạng thái
                        th Thao tác
                tbody 
                    each item in conveyors
                        tr
                            td=item.conveyor_id
                            td=item.name
                            //td=item.line_id
                            td=item.operator_name || "-"
                            td
                                if item.status === "READY" 
                                    | Sẵn sàng
                                else if item.status === "ERROR" 
                                    | Lỗi
                                else if item.status === "OFFLINE" 
                                    | Offline
                                else if item.status === "RUNNING" 
                                    | Đang hoạt động
                                else if item.status === "STOP" 
                                    | STOP
                                else
                                    | #{item.status || "-"}
                            td
                                a.btn.btn--secondary(href=`/conveyors/settings/${item.conveyor_id}`) Sửa
                                form(method="POST" action=`/conveyors/delete/${item.conveyor_id}` style="display:inline-block; margin-left: 8px;")
                                    button.btn.btn--danger(type="submit" onClick="return confirm('Bạn có chắc muốn xóa băng tải này?');") Xóa
block scripts
    if success
        script.
            Toastify({
            text: "#{success}",
            duration: 3000,
            gravity: "top",
            position: "right",
            backgroundColor: "#16a34a",
            close: true
            }).showToast();