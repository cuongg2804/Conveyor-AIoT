extend ../layout/default.pug

block main 
    .page 
        .dashboard_header
            .dashboard_heading
                h1.dashboard_title Quản lý tài khoản
                p.dashboard_subtitle Phân quyền, tạo người dùng hệ thống

            .dashboard-actions
                a.btn.btn-primary(href="/users/create") Thêm tài khoản mới

    if error
      .alert.alert--error
        | #{error}

    .card.history-filter-card
        form.history-filters(method="GET" action="/users")
            .field
                label.field__label(for="keyword") Tìm kiếm người dùng
                input#keyword.field__control(
                    type="text"
                    name="keyword"
                    value=filters.keyword
                    placeholder="Nhập mã hoặc tên người dùng..."
                )
            .field
                label.field__label(for="role") Quyền hạn
                select#role.field__control(name="role")
                    option(value="" selected=!filters.role) Tất cả
                    option(value="ADMIN" selected=filters.role === "ADMIN") Admin
                    option(value="USER" selected=filters.role === "USER") User
            .history-filters__actions
                button.btn.btn--primary(type="submit") Lọc
                a.btn.btn-secondary(href="/users") Xóa
            
    .card
        .table-wrap 
            table.table
                thead
                    tr 
                        th User ID 
                        th Username
                        th Họ tên
                        th Role
                        th Thao tác
                tbody 
                    each item in users
                        tr
                            td=item.user_id 
                            td=item.username
                            td=item.fullname
                            td=item.role 
                            td
                                a.btn.btn--secondary(href=`/users/edit/${item.user_id}`) Sửa
                                form(method="POST" action=`/users/delete/${item.user_id}` style="display:inline-block; margin-left: 8px;")
                                    button.btn.btn--danger(type="submit" onClick="return confirm('Bạn có chắc muốn xóa tài khoản này?');") Xóa