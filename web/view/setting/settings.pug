extend ../layout/default.pug

block main
  .page
    .dashboard__header
      .dashboard__heading
        h1.dashboard__title= title || "Cấu hình băng tải"
        p.dashboard__subtitle Cập nhật thông tin băng tải và cấu hình vận hành

      .dashboard-actions
        a.btn.btn--secondary(href="/dashboard") Quay lại danh sách
        if monitorUrl
          a.btn.btn--primary(href=monitorUrl) Giám sát

    if updated
      .alert.alert--success Cập nhật cấu hình thành công.

    if configSynced
      .alert.alert--success Đã đồng bộ cấu hình.

    if configSyncFailed
      .alert.alert--error Không thể đồng bộ cấu hình.

    .card.settings-card
      form.settings-form(method="POST" action=formAction)
        .settings-section
          .settings-section__head
            h3.settings-section__title Thông tin băng tải
            p.settings-section__desc Cập nhật tên, người vận hành, trạng thái và mô tả băng tải

          .settings-section-grid.settings-section-grid--two
            .field
              label.field__label(for="name") Tên băng tải
              input#name.field__control(type="text" name="name" value=conveyor.name required)

            if user && user.role === "ADMIN"
              .field
                label.field__label(for="operator_id") Người vận hành
                select#operator_id.field__control(name="operator_id")
                  option(value="" selected=!conveyor.operator_id) -- Chưa phân công --
                  each operator in operators
                    option(value=operator.user_id selected=conveyor.operator_id === operator.user_id)
                      | #{operator.fullname || operator.username || operator.user_id}

            .field
              label.field__label(for="description") Mô tả
              textarea#description.field__control(name="description")= conveyor.description || ""

        .settings-section
          .settings-section__head
            h3.settings-section__title Camera
            p.settings-section__desc Chọn camera và thiết lập độ trễ kích hoạt chụp ảnh

          .settings-section-grid
            .field
              label.field__label(for="camera_id") Nguồn camera
              select#camera_id.field__control(name="camera_id")
                option(value="" selected=!config.camera_id) -- Chưa chọn camera --
                each camera in cameras
                  option(value=camera.camera_id selected=config.camera_id === camera.camera_id)
                    | #{camera.camera_name} - #{camera.camera_id}

            .field
              label.field__label(for="camera_trigger_delay") Độ trễ kích hoạt
              input#camera_trigger_delay.field__control(type="number" name="camera_trigger_delay" value=config.camera_trigger_delay || 0)

        .settings-section
          .settings-section__head
            h3.settings-section__title Bộ điều khiển
            p.settings-section__desc Cấu hình cổng serial và tốc độ truyền dữ liệu đến Arduino

          .settings-section-grid.settings-section-grid--control
            .field
              label.field__label(for="serial_port") Cổng kết nối
              select#serial_port.field__control(name="serial_port")
                option(value=config.serial_port selected=config.serial_port)= config.serial_port || "-- Chưa chọn cổng --"

            .field
              label.field__label(for="baud_rate") Tốc độ truyền
              input#baud_rate.field__control(type="number" name="baud_rate" value=config.baud_rate || 9600 required)

        .settings-section
          .settings-section__head
            h3.settings-section__title AI
            p.settings-section__desc Thiết lập ngưỡng đánh giá phục vụ phân loại sản phẩm đạt/không đạt

          .settings-section-column.settings-section-column--small
            .field
              label.field__label(for="ai_threshold") Ngưỡng đánh giá
              input#ai_threshold.field__control(type="number" name="ai_threshold" step="0.000001" value=config.ai_threshold || 30.436506 required)

        .settings-actions
          button.btn.btn--primary(type="submit") Lưu cấu hình
  script(src="/socket.io/socket.io.js")
  script.
    window.CONVEYOR_ID = "#{conveyor.conveyor_id}";

    document.addEventListener("DOMContentLoaded", function () {
      const serialSelect = document.getElementById("serial_port");
      const currentSerialPort = "#{config.serial_port || ''}";

      function renderPorts(ports) {
        if (!serialSelect) return;

        serialSelect.innerHTML = "";

        const emptyOption = document.createElement("option");
        emptyOption.value = "";
        emptyOption.textContent = "-- Chưa chọn cổng --";
        serialSelect.appendChild(emptyOption);

        ports.forEach(function (port) {
          const option = document.createElement("option");
          option.value = port.device;
          option.textContent = port.description
            ? `${port.device} - ${port.description}`
            : port.device;

          if (currentSerialPort === port.device) {
            option.selected = true;
          }

          serialSelect.appendChild(option);
        });

        if (currentSerialPort && !ports.some(function (p) { return p.device === currentSerialPort; })) {
          const currentOption = document.createElement("option");
          currentOption.value = currentSerialPort;
          currentOption.textContent = `${currentSerialPort} - Cổng đã lưu`;
          currentOption.selected = true;
          serialSelect.appendChild(currentOption);
        }
      }

      const socket = io();

      socket.on("serial_ports", function (ports) {
        renderPorts(Array.isArray(ports) ? ports : []);
      });

      fetch("/settings/serial-ports")
        .then(function (res) { return res.json(); })
        .catch(function (err) {
          console.error("Scan serial ports lỗi:", err);
        });
    });