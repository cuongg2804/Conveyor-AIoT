extends ../layout/default.pug

block main
  - const statusLabels = { READY: "Sẵn sàng", STARTING: "Đang khởi động", RUNNING: "Đang hoạt động", STOPPING: "Đang dừng", STOPPED: "Đã dừng", ERROR: "Lỗi" }
  .dashboard
    .dashboard__header
      .dashboard__heading
        h1.dashboard__title Hệ thống kiểm tra sản phẩm
        p.dashboard__subtitle Quản lý băng tải, theo dõi kết quả và cấu hình vận hành

    if errorMessage
      .alert.alert--error
        | #{errorMessage}

    .conveyor-grid
      if conveyorList && conveyorList.length > 0
        each conveyor in conveyorList
          .card.conveyor-card
            .conveyor-card__head
              .conveyor-card__info
                h2 #{conveyor.name}
                if conveyor.description
                  p #{conveyor.description}
                else
                  p Chưa có mô tả

              span.conveyor-status(class=conveyor.status)
                span.status-dot
                | #{statusLabels[conveyor.status] || "Sẵn sàng"}

            .conveyor-meta
              .conveyor-meta__item
                span Mã băng tải
                strong #{conveyor.conveyor_id}

              .conveyor-meta__item
                span Nguồn camera
                strong #{conveyor.camera_name}

              .conveyor-meta__item
                span Cổng điều khiển
                strong #{conveyor.serial_port}

              .conveyor-meta__item
                span Tốc độ truyền
                strong #{conveyor.baud_rate}

              .conveyor-meta__item
                span Độ trễ camera
                strong #{conveyor.camera_trigger_delay}

              .conveyor-meta__item
                span Ngưỡng đánh giá
                strong #{conveyor.ai_threshold}

            .conveyor-actions
              a.btn.btn--primary(href=`/inspection/monitor/${conveyor.conveyor_id}`) Giám sát
              a.btn.btn--secondary(href=`/settings/${conveyor.conveyor_id}`) Cấu hình
      else
        .card
          .empty-state
            h3 Chưa có băng tải
            p Chưa có dữ liệu băng tải trong hệ thống.
