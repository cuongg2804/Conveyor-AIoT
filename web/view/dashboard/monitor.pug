extends ../layout/default.pug

block main
  .dashboard(data-conveyor-code=conveyor.conveyor_code)
    .dashboard__header
      .dashboard__heading
        h1.dashboard__title #{conveyor.name}
        p.dashboard__subtitle Giám sát kết quả kiểm tra AI theo thời gian thực

      .dashboard-actions
        a.btn.btn--secondary(href=dashboardUrl) Quay lại
        a.btn.btn--primary(href=settingsUrl) Thiết lập thông số

      .dashboard__status-pill(class=conveyor.status)
        span.status-dot
        span#systemStatusText #{conveyor.status || "Đang chờ dữ liệu"}

    .inspection-layout
      .preview-panel.card
        .card__head.preview-panel__head
          div
            h2.card__title ẢNH PREVIEW KIỂM TRA
            p.card__desc Hiển thị Frame 2 làm ảnh đại diện cho lần kiểm tra
          .preview-frame-meta
            span Frame 2
            strong#framePreviewScore -

        .main-preview
          .main-preview__label Overlay
          .main-preview__image
            img#overlayPreviewImage(src="" alt="Overlay Preview Frame 2")
            .image-placeholder Chưa có ảnh overlay

        .thumb-grid.thumb-grid--one
          .thumb-box
            .thumb-box__title ROI
            .thumb-box__image
              img#roiPreviewImage(src="" alt="ROI Preview Frame 2")
              .image-placeholder Chưa có ảnh ROI

      .side-panel
        .card.control-card
          .card__head
            h2.card__title ĐIỀU KHIỂN NHANH
            p.card__desc Start / Stop hệ thống AI và băng tải

          .btn-row
            button.btn.btn--success(type="button" onclick="sendControlCommand('START_SYSTEM')") Start
            button.btn.btn--danger(type="button" onclick="sendControlCommand('STOP_SYSTEM')") Stop
            button.btn.btn--secondary(type="button" onclick="sendControlCommand('GET_STATUS')") Trạng thái

          .control-ack-box
            p#lastControlAck Chưa có phản hồi

        .result-card.card
          .card__head
            h2.card__title KẾT QUẢ KIỂM TRA
            p.card__desc Kết quả mới nhất từ hệ thống AI

          .result-main
            span#resultLabel.result-badge -

          .inspection-summary
            .summary-row
              span.summary-label Job ID
              span#jobId.summary-value -

            .summary-row
              span.summary-label Average Score
              span#averageScore.summary-value -

            .summary-row
              span.summary-label Frame Label
              span#framePreviewLabel.summary-value -

            .summary-row
              span.summary-label Thời gian
              span#resultTimestamp.summary-value -

        .card
          .card__head
            h2.card__title TRẠNG THÁI HỆ THỐNG
            p.card__desc Kết nối backend, MQTT broker và AI

          .system-status
            span.system-status__label MQTT
            span#systemStatus.system-status__value
              span.status-dot
              | Chưa kết nối

          .system-status
            span.system-status__label AI
            span#aiStatus.system-status__value(class=conveyor.status)
              span.status-dot
              | #{conveyor.status || "Chưa rõ"}

          .system-status
            span.system-status__label Backend
            span.system-status__value.connected
              span.status-dot
              | Đang chạy

  script.
    window.__LATEST_INSPECTION__ = !{JSON.stringify(latestInspection || null)};
